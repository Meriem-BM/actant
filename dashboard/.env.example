# Privy App ID - required for wallet connection in the Control Panel
# Create a free account at https://dashboard.privy.io and copy your App ID
NEXT_PUBLIC_PRIVY_APP_ID=

# RPC URLs
BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/<YOUR_API_KEY>
BASE_MAINNET_RPC_URL=https://base-mainnet.g.alchemy.com/v2/<YOUR_API_KEY>
NEXT_PUBLIC_RPC_URL=https://base-sepolia.g.alchemy.com/v2/<YOUR_API_KEY>

# Contract addresses - copy from packages/contracts/deployment.env after deploying
REGISTRY_ADDRESS=0x...
FACTORY_ADDRESS=0x...
NEXT_PUBLIC_REGISTRY_ADDRESS=0x...
NEXT_PUBLIC_FACTORY_ADDRESS=0x...
NEXT_PUBLIC_CHAIN_ID=84532

# ERC-4337 Bundler URL - required for the full UserOp flow
# `NEXT_PUBLIC_BUNDLER_URL` is used by the browser demo when signing with Privy.
# When omitted, pay() calls the contract directly (useful for local dev with Anvil)
#
# Options:
#   Pimlico (free tier):  https://api.pimlico.io/v2/base-sepolia/rpc?apikey=<key>
#   Alchemy:              https://bundler.alchemy.com/v2/<apikey>
#   Public (no key):      https://public.pimlico.io/v1/base-sepolia/rpc
NEXT_PUBLIC_BUNDLER_URL=https://public.pimlico.io/v1/base-sepolia/rpc
